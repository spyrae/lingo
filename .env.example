# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# SQLite database path
DB_PATH=data/lingo.db

# Codex CLI
# OPENAI_API_KEY should be set in your environment (do not commit it)
CODEX_COMMAND=codex
CODEX_TIMEOUT_SECONDS=60

# JSON array of Telegram user IDs allowed to use the bot
# Example: [123456789]
ALLOWED_USER_IDS=[]

# Allow all users (security risk; prefer ALLOWED_USER_IDS)
ALLOW_ALL_USERS=false


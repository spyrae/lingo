# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# SQLite database path
DB_PATH=data/lingo.db

# Content data directory
DATA_DIR=data

# OpenAI API (legacy, not used with Claude CLI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano
OPENAI_TIMEOUT_SECONDS=60

# Claude CLI (uses subscription, no API key needed)
CLAUDE_MODEL=sonnet
CLAUDE_TIMEOUT_SECONDS=120

# JSON array of Telegram user IDs allowed to use the bot
# Example: [123456789]
ALLOWED_USER_IDS=[]

# Allow all users (security risk; prefer ALLOWED_USER_IDS)
ALLOW_ALL_USERS=false

# Language configuration (see docs/CHANGING_LANGUAGE.md)
TARGET_LANGUAGE=Indonesian
TARGET_LANGUAGE_NATIVE=индонезийский
TARGET_FLAG=🇮🇩
NATIVE_FLAG=🇷🇺
WELCOME_PHRASE=Selamat datang!

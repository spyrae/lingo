  "prerequisites": ["grammar-05"],
  "theory": {
    "text": "Многие базовые глаголы в индонезийском используются без аффиксов в разговорной речи. Они не меняются по лицам и числам.",
    "key_points": [
      "makan — есть",
      "minum — пить",
      "pergi — идти/уходить",
      "datang — приходить",
      "tinggal — жить/останавливаться"
    ]
  },
  "examples": [
    {
      "indonesian": "Saya makan nasi setiap pagi.",
      "russian": "Я ем рис каждое утро.",
      "notes": "makan = есть"
    },
    {
      "indonesian": "Dia tinggal di Bali.",
      "russian": "Он/она живёт на Бали.",
      "notes": "tinggal = жить/проживать"
    }
  ],
  "exercises": [
    {
      "type": "choice",
      "question": "Как сказать «пить кофе»?",
      "options": [
        "makan kopi",
        "minum kopi",
        "pergi kopi",
        "datang kopi"
      ],
      "correct": 1,
      "explanation": "minum = пить."
    },
    {
      "type": "translate",
      "question": "Переведи: «Мы живём в Джакарте.»",
      "indonesian": "Kami tinggal di Jakarta.",
      "accept": [
        "kami tinggal di jakarta"
      ],
      "explanation": "kami — мы (без собеседника), tinggal — жить."
    }
  ],
